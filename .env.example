# Supabase — değerleri kendi projenizden alın (Dashboard > Project Settings > API)
# Bu dosyayı .env olarak kopyalayıp doldurun. .env git'e gönderilmez.

# Client (tarayıcıya gider — güvenli, public anahtarlar):
VITE_SUPABASE_URL=https://XXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# Sadece yerel migration script'i için (GİZLİ — asla client'a/Vercel'e koymayın):
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
